# OpenRouter API Key (ASR + transcript correction via Gemini)
OPENROUTER_API_KEY=your-key

# Fish Audio API Key (voice clone + TTS)
FISH_API_KEY=your-key

# Anthropic API Key (Claude Agent SDK)
ANTHROPIC_API_KEY=your-key

# Claude model (optional, default: claude-sonnet-4-20250514)
# CLAUDE_MODEL=claude-sonnet-4-20250514

# Workspaces root directory (optional, default: workspaces)
# WORKSPACES_ROOT=workspaces
